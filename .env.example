# General App Settings
PLAYGROUND_APP_ENV=development
PLAYGROUND_LOG_LEVEL=INFO

# Rate Limiting (Token Bucket)
PLAYGROUND_TOKEN_BUCKET_CAPACITY=10
PLAYGROUND_TOKEN_BUCKET_REFILL_RATE=1

# AWS / S3 Configuration
PLAYGROUND_S3_ENDPOINT_URL=
PLAYGROUND_S3_ACCESS_KEY=
PLAYGROUND_S3_SECRET_KEY=
PLAYGROUND_S3_REGION_NAME=us-east-1
PLAYGROUND_S3_BUCKET_NAME=
PLAYGROUND_SIGNED_URL_EXPIRY=3600

# LLM Provider API Keys
PLAYGROUND_OPENAI_API_KEY=
PLAYGROUND_ANTHROPIC_API_KEY=

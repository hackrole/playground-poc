# General App Settings
PLAYGROUND_APP_ENV=local
PLAYGROUND_LOG_LEVEL=DEBUG

# Rate Limiting (Token Bucket)
PLAYGROUND_TOKEN_BUCKET_CAPACITY=100
PLAYGROUND_TOKEN_BUCKET_REFILL_RATE=10

# AWS / S3 Configuration (Local Minio)
# Note: use http://localhost:9000 for local dev, or http://minio:9000 if inside Docker
PLAYGROUND_S3_ENDPOINT_URL=http://localhost:9000
PLAYGROUND_S3_ACCESS_KEY=minioadmin
PLAYGROUND_S3_SECRET_KEY=minioadmin
PLAYGROUND_S3_REGION_NAME=us-east-1
PLAYGROUND_S3_BUCKET_NAME=playground-bucket
PLAYGROUND_SIGNED_URL_EXPIRY=3600

# LLM Provider API Keys
PLAYGROUND_OPENAI_API_KEY=sk-placeholder-key
PLAYGROUND_ANTHROPIC_API_KEY=ant-placeholder-key
